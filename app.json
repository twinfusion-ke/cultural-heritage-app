{
  "expo": {
    "name": "Cultural Heritage",
    "slug": "cultural-heritage",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "culturalheritage",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e382c"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.twinfusion.culturalheritage",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan QR codes on artworks to view details and reserve items.",
        "NSLocationWhenInUseUsageDescription": "Tag your location when scanning artworks at the Cultural Heritage Centre.",
        "NSMicrophoneUsageDescription": "Record audio feedback about artworks."
      }
    },
    "android": {
      "package": "com.twinfusion.culturalheritage",
      "versionCode": 4,
      "adaptiveIcon": {
        "backgroundColor": "#0e382c",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-navigation-bar",
      [
        "expo-camera",
        {
          "cameraPermission": "Scan QR codes on artworks to view details and reserve items."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Tag your location when scanning artworks."
        }
      ],
      "expo-av"
    ],
    "updates": {
      "url": "https://u.expo.dev/2e487001-d78d-484a-9f35-2c233ba546f0"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "2e487001-d78d-484a-9f35-2c233ba546f0"
      },
      "expo-navigation-bar": {}
    },
    "owner": "e-agesa"
  }
}
